# Для текущей localStorage-версии CRM переменные окружения не требуются.

# Следующий этап для общей базы и настоящей авторизации сотрудников.
# В браузер можно отдавать только publishable/anon ключ. Service role сюда не добавлять.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Только для серверных API-роутов. Никогда не добавлять префикс NEXT_PUBLIC.
# SUPABASE_SERVICE_ROLE_KEY=
# STAFF_ADMIN_SETUP_TOKEN=
